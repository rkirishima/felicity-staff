{
  "crons": [
    {
      "path": "/api/cron/timeclock-alert",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/attendance-audit",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/prep-alert",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/monthly-roast-invoice",
      "schedule": "0 0 1 * *"
    },
    {
      "path": "/api/cron/tax-anomaly-check",
      "schedule": "0 0 * * 1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        },
        {
          "key": "Surrogate-Control",
          "value": "no-store"
        },
        {
          "key": "CDN-Cache-Control",
          "value": "no-store"
        },
        {
          "key": "Vercel-CDN-Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}